library(affy)
library(limma)
library(geNetClassifier)
library(pheatmap)
data <- ReadAffy()
sampleNames(data)
eset <- rma(data)
expr <- exprs(eset)
dim(expr)
head(expr)
labels <- factor(c(
rep("Control",11),
rep("Disease",11)
))
length(labels)
sample_dist <- dist(t(expr))
hc <- hclust(sample_dist)
plot(hc)
pheatmap(expr)
pca <- prcomp(t(expr))
plot(
pca$x[,1],
pca$x[,2],
col = as.numeric(labels),
pch = 19
)
design <- model.matrix(~labels)
fit <- lmFit(expr, design)
fit <- eBayes(fit)
results <- topTable(
fit,
coef = 2,
number = 20
)
results
write.csv(results, "Top_DE_Genes.csv")
volcanoplot(fit, coef=2)
model <- geNetClassifier(
eset = expr,
sampleLabels = labels
)
class(model)
slotNames(model)
model@classificationGenes
model@genesRanking
save(
model,
file = "geNetClassifier_model.RData"
)
