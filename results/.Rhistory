bio_data <- data.frame(
GeneExpression = c(4.5,5.2, 6.1, 6.8),
ProteinLevel   = c(10,12, 14, 15, 17),
EnzymeActivity = c(30,34, 38, 41, 45)
)
bio_data <- data.frame(
GeneExpression = c(4.5,5.2, 6.1, 6.8,9.5),
ProteinLevel   = c(10,12, 14, 15, 17),
EnzymeActivity = c(30,34, 38, 41, 45)
)
#corelation
# Correlation between Gene Expression and Protein Level
cor(bio_data$GeneExpression, bio_data$ProteinLevel)
# Correlation between Gene Expression and Enzyme Activity
cor(bio_data$GeneExpression, bio_data$EnzymeActivity)
# Simple linear regression
simple_lm <- lm(ProteinLevel ~ GeneExpression, data = bio_data)
# Model summary
summary(simple_lm)
# Multiple linear regression
multi_lm <- lm(EnzymeActivity ~ GeneExpression + ProteinLevel, data = bio_data)
# Model summary
summary(multi_lm)
# Correlation matrix
cor_matrix <- cor(bio_data)
# View matrix
cor_matrix
