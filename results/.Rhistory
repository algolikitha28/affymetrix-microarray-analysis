library(ggplot2)
bio_data <- data.frame(
GeneExpression = c(5.2, 6.1, 5.8, 7.3, 6.9, 8.1),
ProteinLevel   = c(12, 14, 13, 16, 15, 18),
Treatment      = c("Control", "Control", "Control",
"Drug", "Drug", "Drug")
)
#histogram
ggplot(bio_data, aes(x = GeneExpression)) +
geom_histogram(binwidth = 0.5, fill = "skyblue", color = "black") +
labs(
title = "Histogram of Gene Expression Levels",
x = "Gene Expression",
y = "Frequency"
) +
theme_minimal()
ggplot(bio_data, aes(x = Treatment, y = GeneExpression, fill = Treatment)) +
geom_boxplot() +
labs(
title = "Boxplot of Gene Expression by Treatment",
x = "Treatment Type",
y = "Gene Expression"
) +
theme_minimal()
ggplot(bio_data, aes(x = GeneExpression, y = ProteinLevel, color = Treatment)) +
geom_point(size = 3) +
labs(
title = "Scatter Plot of Gene Expression vs Protein Level",
x = "Gene Expression",
y = "Protein Level (µg/ml)"
) +
theme_minimal()
ggplot(bio_data, aes(x =GeneExpression, y = ProteinLevel, fill = Treatment)) +
geom_bar(stat = "identity") +
labs(
title = "Bar Graph of Mean Gene Expression Levels",
x = "Treatment",
y = "Mean Gene Expression"
) +
theme_minimal()
